# Copy this file to .env and fill in the values

# PostgreSQL connection string
# Default matches the Docker run command below
DATABASE_URL=postgresql://bei_yangu_admin:1423Okello,@localhost:5501/bei_yangu_db

# Gemini API key for AI-powered symptom search (optional but recommended)
# Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to true to force re-seed the database on every startup (dev only)
SEED_FORCE=false

# Set to false to disable auto-seeding
SEED_ON_STARTUP=true
